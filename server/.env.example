# Example environment for development
# Copy to .env and adjust values (this file is safe to commit)

# Project-scoped local Postgres (no Docker)
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=trafficmena_app
PGPASSWORD=CHANGE_ME_APP
PGDATABASE=trafficmena_dev
PGSSLMODE=disable
DATABASE_URL=postgres://trafficmena_app:CHANGE_ME_APP@127.0.0.1:5433/trafficmena_dev
DATABASE_ADMIN_URL=postgres://trafficmena_admin:CHANGE_ME_ADMIN@127.0.0.1:5433/trafficmena_dev

# Better Auth Configuration (generate at least 32 random characters; rotate per environment)
BETTER_AUTH_SECRET=replace-with-32-char-random-secret
BETTER_AUTH_ISSUER=http://localhost:3001
INVITE_SESSION_SECRET=change-me-in-production

# Email Service (Plunk)
PLUNK_API_KEY=your-plunk-api-key

# CORS Configuration (comma-separated list, no wildcards when credentials are used)
CORS_ORIGIN=http://localhost:5173

# App Base URLs (used for payment redirects and webhooks)
APP_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:3001

# BunnyCDN Storage (optional – required for image uploads)
BUNNY_STORAGE_ZONE=your-storage-zone-name
# Use the Storage Zone password (not the read-only key) for API uploads
BUNNY_STORAGE_ACCESS_KEY=your-storage-zone-password
BUNNY_STORAGE_CDN_URL=https://your-zone.b-cdn.net

# Invitation daily limit per admin (optional – defaults to 1000)
# INVITATION_DAILY_LIMIT=1000

# Cloudflare Turnstile CAPTCHA (optional – required for event mode abuse protection)
# Get keys from https://dash.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
